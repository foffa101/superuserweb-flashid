rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if the user is logged in via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: checks if the logged-in user's UID matches the document's userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles — only the account owner can read/write their own profile
    // Used by: web-flashid (read profile after SSO), app-flashid (create/update profile on setup)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User settings — security settings persisted to Firestore (replaces localStorage)
    // Only the account owner can read/write their own settings
    // Used by: web-flashid, adminweb-flashid, superuserweb-flashid (settings pages)
    match /user_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Voice biometric data — only the owner can access their voiceprint
    // Used by: web-flashid (read enrollment status), app-flashid (write during enrollment)
    match /voiceprints/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Fingerprint biometric data — only the owner can access their fingerprint
    // Used by: web-flashid (read enrollment status), app-flashid (write during enrollment)
    match /fingerprints/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Face biometric data — only the owner can access their faceprint
    // Used by: web-flashid (read enrollment status), app-flashid (write during enrollment)
    match /faceprints/{userId} {
      allow read, write: if isOwner(userId);
    }

    // QR login sessions (web <-> app verification flow)
    // Any logged-in user can create a session or read session status
    // Only the user who CREATED the session (userId field) can approve/update it
    // This prevents a different user's app from approving someone else's login
    // Used by: web-flashid (create session + listen for approval), app-flashid (update session to approved after biometric)
    // QR login sessions (web <-> app verification flow)
    // Any authenticated user can create, read, or update a session
    // Security is enforced by: challenge token (must match QR), session expiry, biometric verification
    // The app user approving may have a different UID than the portal user who created the session
    match /auth_sessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // Sites authorized via the Flash ID app (synced to web portal)
    // Only the owner can read/write their own authorized sites list
    // Used by: app-flashid (write when user approves a site via QR), web-flashid (read to display in Vault)
    match /authorized_sites/{userId}/sites/{siteId} {
      allow read, write: if isOwner(userId);
    }

    // Super admin portal configuration (whitelist, settings)
    // Any authenticated user can READ (needed for whitelist check on login)
    // Only existing whitelisted admins can WRITE (modify the whitelist)
    // The portal code checks the whitelist and blocks unauthorized users at the app level
    // Used by: superuserweb-flashid (read whitelist to check access on login)
    match /superadmin_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Admin portal configuration (whitelist managed by super admin)
    match /admin_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Field Agents (action approval watchers, super admin portal)
    match /field_agents/{agentId} {
      allow read, write: if isAuthenticated();
    }

    // Tenant management (super admin portal)
    match /tenants/{tenantId} {
      allow read, write: if isAuthenticated();
    }

    // Invoices (super admin portal)
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    // Platform events log (super admin portal)
    match /platform_events/{eventId} {
      allow read, write: if isAuthenticated();
    }

    // Banned IPs (super admin portal)
    match /banned_ips/{banId} {
      allow read, write: if isAuthenticated();
    }

    // Platform config — stats, security settings (super admin portal)
    match /platform_config/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /security_config/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Admin approval requests (push-to-approve for whitelist changes)
    // Portal creates, app reads and updates status
    match /admin_approvals/{approvalId} {
      allow read, write: if isAuthenticated();
    }

    // Verification event logs (audit trail)
    // Users can only read their own logs
    // Users can only create logs with their own userId
    // Used by: web-flashid (read + display in Events page), app-flashid (future: write after verification)
    // Not used by: wp-flashid (has its own internal security log in WordPress DB)
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // --- Agent Approvals (KYA + KYC) ---

    // Tenant admins — maps admin UIDs to tenants
    // Read: tenant admin (own record) or superuser
    // Write + delete: authenticated users (super admin cleans up stale docs when
    // deleting tenants or revoking access). Backend Admin SDK bypasses rules.
    match /tenant_admins/{docId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // Business agents — registered API agents per tenant
    // Read: tenant admin whose tenantId matches, or superuser
    // Write: authenticated users (POC — production should restrict to backend + tenant admin)
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Connected customers — pairing between tenants and Flash ID users
    // Read: tenant admin whose tenantId matches, OR the paired customer
    // Write: backend only
    match /connected_customers/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Agent approval requests — pending/approved/denied decisions
    // Read: tenant admin whose tenantId matches, OR the customer whose UID matches
    // Write: backend only
    match /approvals/{approvalId} {
      allow read: if isAuthenticated() && (
        resource.data.tenantId == request.auth.token.tenantId
        || resource.data.customerUid == request.auth.uid
      );
    }

    // Consent records — immutable QR verification consent log.
    // Owner can create their own record; update is limited to setting
    // revokedAt (revocation) — the original consent metadata is preserved.
    match /consent_records/{recordId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revokedAt']);
    }

    // Scope categories — superuser-owned seed data
    // Read: any authenticated user
    // Write: superuser only (via backend for POC)
    match /scope_categories/{categoryId} {
      allow read: if isAuthenticated();
    }

    // Chat conversations — both participants can read/write messages
    // Used by: app-flashid (People > Message button)
    match /conversations/{convId} {
      allow read, write: if isAuthenticated();
      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Interaction events — user can read/write their own activity log
    // Used by: app-flashid (Interactions screen with real-time listener)
    match /interactions/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Consent log — login consent events from WP and portal
    // Used by: adminweb-flashid (Consent Log page), app-flashid (logConsent on approval)
    match /consent_log/{docId} {
      allow read, write: if isAuthenticated();
    }

    // SIWE nonces — temporary nonces for wallet authentication
    // Used by: agentapi-flashid (create/verify), web-flashid (wallet-auth page)
    match /siwe_nonces/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Admin activity log — portal login tracking (super admin + admin portals)
    match /admin_activity/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Interaction requests — mutual-consent contact adds between two Flash ID
    // users. Keyed by flashidUid (16-hex) on both sides; the server-side rule
    // resolves request.auth.uid → flashid_uid via the caller's users doc so
    // each party can only see requests where they're the sender or recipient.
    // Status transitions:
    //   pending  → approved | rejected | cancelled | revoked
    //   approved → revoked
    // Cancel = silent delete (sender only, while pending).
    // Revoke = status=revoked with revokedBy set (either side, after approved).
    match /interaction_requests/{requestId} {
      function myFlashidUid() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flashid_uid;
      }
      function isParty() {
        return isAuthenticated() && (
          resource.data.fromFlashidUid == myFlashidUid() ||
          resource.data.toFlashidUid == myFlashidUid()
        );
      }
      allow read: if isParty();
      allow create: if isAuthenticated()
        && request.resource.data.fromAuthUid == request.auth.uid
        && request.resource.data.fromFlashidUid == myFlashidUid()
        && request.resource.data.status == "pending";
      allow update: if isParty();
      allow delete: if isParty();
    }

    // Catch-all: deny everything not explicitly allowed above
    // Applies to: all apps — any collection not listed above is blocked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
